{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/JMSServerCreateRequest",
  "title": "JMSServerCreateRequest",
  "type": "object",
  "required": [
    "name"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "JMS server name"
    },
    "messagesMaximum": {
      "type": "integer"
    },
    "bytesMaximum": {
      "type": "integer"
    },
    "targets": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Identity"
      }
    },
    "persistentStore": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}